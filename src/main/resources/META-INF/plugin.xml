<idea-plugin>
    <id>com.austinv11.nextflow</id>
    <name>Nextflow LSP</name>
    <vendor>austinv11</vendor>
    <description><![CDATA[
    Nextflow LSP support for IntelliJ IDEA and PyCharm.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.intellij.groovy</depends>
    <depends>org.jetbrains.plugins.textmate</depends>
    <depends config-file="lsp.xml">com.intellij.modules.lsp</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Nextflow" language="Groovy" implementationClass="com.austinv11.nextflow.NextflowFileType" fieldName="INSTANCE" extensions="nf" fileNames="nextflow.config"/>

        <projectConfigurable
                groupId="tools"
                displayName="Nextflow"
                id="com.austinv11.nextflow.settings"
                instance="com.austinv11.nextflow.NextflowSettingsConfigurable"/>

        <textmate.bundleProvider implementation="com.austinv11.nextflow.NextflowTextMateBundleProvider"/>
    </extensions>

    <extensions defaultExtensionNs="org.intellij.groovy">
        <unresolvedHighlightFileFilter implementation="com.austinv11.nextflow.NextflowUnresolvedHighlightFileFilter"/>
    </extensions>
</idea-plugin>