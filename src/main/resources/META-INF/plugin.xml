<idea-plugin>
    <id>com.austinv11.nextflow</id>
    <name>Nextflow Support</name>
    <vendor>austinv11</vendor>
    <description><![CDATA[
    Enhanced Nextflow support for IntelliJ IDEA and PyCharm.

    We include syntax highlighting, code completion, and error checking for Nextflow files using the official
    Nextflow Language Server and the official syntax highlighting TextMate bundle.

    Additionally, the plugin integrates with native Jetbrains IDE features like run configurations, debugging support,
    enhanced Groovy support, helpful hints, file templates, and more!
    ]]></description>

    <dependencies>
        <plugin id="com.intellij.modules.platform"/>
        <plugin id="org.intellij.groovy"/>
        <plugin id="org.jetbrains.plugins.textmate"/>
        <plugin id="org.jetbrains.plugins.terminal"/>
        <plugin id="com.jetbrains.sh"/>
        <!-- intellij.textmate must be listed explicitly so its module classloader
             is accessible — required for TextMateBundleProvider to resolve. -->
        <module name="intellij.textmate"/>
        <module name="intellij.platform.lsp"/>
    </dependencies>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Nextflow" language="Nextflow" implementationClass="com.austinv11.nextflow.NextflowFileType" fieldName="INSTANCE" extensions="nf;nf.test" fileNames="nextflow.config"/>

        <!-- Delegate parsing to Groovy — Nextflow is Groovy-based, so Groovy's lexer/parser
             give IntelliJ a proper PSI tree and correct prefix computation for completion.
             createFile() is overridden to use NextflowLanguage so the file root is Nextflow,
             not Groovy. Syntax highlighting is intentionally left to the TextMate bundle
             so that Nextflow-specific keywords (process, workflow, channel operators) are
             highlighted correctly. -->
        <lang.parserDefinition language="Nextflow" implementationClass="com.austinv11.nextflow.NextflowParserDefinition"/>
        <lang.commenter language="Nextflow" implementationClass="org.jetbrains.plugins.groovy.highlighter.GroovyCommenter"/>
        <lang.braceMatcher language="Nextflow" implementationClass="org.jetbrains.plugins.groovy.highlighter.GroovyBraceMatcher"/>
        <lang.quoteHandler language="Nextflow" implementationClass="org.jetbrains.plugins.groovy.editor.GroovyQuoteHandler"/>
        <lang.syntaxHighlighter language="Nextflow" implementationClass="com.austinv11.nextflow.NextflowSyntaxHighlighter"/>
        <lang.syntaxHighlighterFactory language="Nextflow" implementationClass="com.austinv11.nextflow.NextflowSyntaxHighlighterFactory"/>

        <fileTypeOverrider implementation="com.austinv11.nextflow.NextflowFileTypeOverrider"/>
        <typedHandler implementation="com.austinv11.nextflow.NextflowCompletionAutoPopupHandler"/>

        <projectConfigurable
                groupId="tools"
                displayName="Nextflow"
                id="com.austinv11.nextflow.settings"
                instance="com.austinv11.nextflow.NextflowSettingsConfigurable"/>

        <textmate.bundleProvider implementation="com.austinv11.nextflow.NextflowTextMateBundleProvider"/>
        <platform.lsp.serverSupportProvider implementation="com.austinv11.nextflow.lsp.NextflowLspServerSupportProvider"/>
        <toolWindow id="Nextflow"
                    anchor="right"
                    icon="com.austinv11.nextflow.NextflowIcons.FILE"
                    factoryClass="com.austinv11.nextflow.toolwindow.NextflowToolWindowFactory"
                    doNotActivateOnStart="true"/>
        <notificationGroup id="Nextflow Missing" displayType="STICKY_BALLOON"/>
        <internalFileTemplate name="Nextflow Script"/>
        <internalFileTemplate name="Nextflow Process"/>
        <internalFileTemplate name="Nextflow Config"/>
        <internalFileTemplate name="Nextflow Test"/>
        <editorNotificationProvider implementation="com.austinv11.nextflow.inspections.NextflowMissingFilesNotificationProvider"/>
        <multiHostInjector implementation="com.austinv11.nextflow.NextflowLanguageInjector"/>
        <psi.referenceContributor language="Nextflow" implementation="com.austinv11.nextflow.NextflowFileReferenceContributor"/>
        <configurationType implementation="com.austinv11.nextflow.execution.NextflowRunConfigurationType" />
        <runConfigurationProducer implementation="com.austinv11.nextflow.execution.NextflowRunConfigurationProducer" />
        <codeInsight.lineMarkerProvider language="Nextflow" implementationClass="com.austinv11.nextflow.execution.NextflowRunLineMarkerContributor" />
        <programRunner implementation="com.austinv11.nextflow.execution.NextflowDebugRunner" />
    </extensions>

    <actions>
        <action id="Nextflow.ConvertPipelineToTyped" class="com.austinv11.nextflow.lsp.NextflowConvertPipelineToTypedAction" text="Convert Pipeline to Static Types" description="Convert Nextflow pipeline to static types">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="Nextflow.ConvertScriptToTyped" class="com.austinv11.nextflow.lsp.NextflowConvertScriptToTypedAction" text="Convert Script to Static Types" description="Convert Nextflow script to static types">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
        <action id="Nextflow.Format" class="com.austinv11.nextflow.lsp.NextflowFormatAction" text="Format Nextflow (LSP)" description="Format Nextflow file using the LSP server">
            <add-to-group group-id="CodeMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action id="Nextflow.NewFile" class="com.austinv11.nextflow.actions.NextflowCreateFileAction" text="Nextflow File" description="Create a new Nextflow file" icon="com.austinv11.nextflow.NextflowIcons.FILE">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewFile" />
        </action>
        <action id="Nextflow.Console" class="com.austinv11.nextflow.actions.NextflowConsoleAction" text="Nextflow Console" description="Launch an interactive Nextflow console" icon="com.austinv11.nextflow.NextflowIcons.FILE">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
