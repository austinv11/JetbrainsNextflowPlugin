<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">
        <lang.commenter language="Nextflow" implementationClass="org.jetbrains.plugins.groovy.highlighter.GroovyCommenter"/>
        <lang.braceMatcher language="Nextflow" implementationClass="org.jetbrains.plugins.groovy.highlighter.GroovyBraceMatcher"/>
        <lang.quoteHandler language="Nextflow" implementationClass="org.jetbrains.plugins.groovy.editor.GroovyQuoteHandler"/>
        <typedHandler implementation="com.austinv11.nextflow.NextflowCompletionAutoPopupHandler"/>
        <psi.referenceContributor language="Nextflow" implementation="com.austinv11.nextflow.NextflowFileReferenceContributor"/>
        <codeInsight.lineMarkerProvider language="Nextflow" implementationClass="com.austinv11.nextflow.execution.NextflowRunLineMarkerContributor" />
    </extensions>
</idea-plugin>
